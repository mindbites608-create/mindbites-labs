---
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Blog</title>
  </head>

  <body>
    <h1>MindBites Blog</h1>

    <ul>
      {posts.map((post) => (
        <li>
          <strong>{post.data.title}</strong>
          <br />
          {post.data.description}
        </li>
      ))}
    </ul>
  </body>
</html>