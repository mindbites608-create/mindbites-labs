---
import { siteConfig } from "../config/site";

const { features } = siteConfig;
---

<section class="bg-gray-50 py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="text-4xl font-bold text-gray-900">
        Why MindBites Labs?
      </h2>

      <p class="mt-4 text-lg text-gray-600">
        Everything you need to build and scale modern AI-powered publishing businesses.
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      {
        features.map((feature) => (
          <div class="rounded-2xl bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
            <div class="text-5xl">{feature.icon}</div>

            <h3 class="mt-6 text-xl font-semibold text-gray-900">
              {feature.title}
            </h3>

            <p class="mt-3 text-gray-600">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>