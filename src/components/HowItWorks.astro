---
import { siteConfig } from "../config/site";

const { howItWorks } = siteConfig;
---

<section class="bg-white py-24">
  <div class="mx-auto max-w-6xl px-6">

    <div class="text-center">
      <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-medium text-blue-700">
        {howItWorks.badge}
      </span>

      <h2 class="mt-6 text-4xl font-bold tracking-tight text-gray-900 md:text-5xl">
        {howItWorks.heading}
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-gray-600">
        {howItWorks.description}
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-4">

      {howItWorks.steps.map((step) => (
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm transition hover:shadow-md">

          <div class="text-3xl font-extrabold text-blue-600">
            {step.number}
          </div>

          <h3 class="mt-4 text-xl font-semibold text-gray-900">
            {step.title}
          </h3>

          <p class="mt-3 text-gray-600">
            {step.description}
          </p>

        </div>
      ))}

    </div>
  </div>
</section>