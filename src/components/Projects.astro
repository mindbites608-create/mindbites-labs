---
import { siteConfig } from "../config/site";

const { projects } = siteConfig;
---

<section class="bg-gray-50 py-24">
  <div class="mx-auto max-w-6xl px-6">

    <div class="text-center">
      <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-medium text-blue-700">
        {projects.badge}
      </span>

      <h2 class="mt-6 text-4xl font-bold tracking-tight text-gray-900 md:text-5xl">
        {projects.heading}
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-gray-600">
        {projects.description}
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3">

      {projects.items.map((project) => (
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">

          <span class="inline-block rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-700">
            {project.category}
          </span>

          <h3 class="mt-5 text-2xl font-semibold text-gray-900">
            {project.title}
          </h3>

          <p class="mt-4 leading-7 text-gray-600">
            {project.description}
          </p>

        </div>
      ))}

    </div>

  </div>
</section>