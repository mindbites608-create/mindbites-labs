---
import { siteConfig } from "../config/site";

const { cta } = siteConfig;
---

<section class="bg-gray-50 py-24">
  <div class="mx-auto max-w-5xl px-6">
    <div class="rounded-3xl bg-white p-12 text-center shadow-sm">

      <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-medium text-blue-700">
        {cta.badge}
      </span>

      <h2 class="mt-6 text-4xl font-bold tracking-tight text-gray-900 md:text-5xl">
        {cta.heading}
      </h2>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-gray-600">
        {cta.description}
      </p>

      <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
        <a
          href={cta.primaryButton.href}
          class="rounded-xl bg-blue-600 px-8 py-4 font-semibold text-white transition hover:bg-blue-700"
        >
          {cta.primaryButton.text}
        </a>

        <a
          href={cta.secondaryButton.href}
          class="rounded-xl border border-gray-300 px-8 py-4 font-semibold text-gray-700 transition hover:bg-gray-100"
        >
          {cta.secondaryButton.text}
        </a>
      </div>

    </div>
  </div>
</section>